PORT=8000
HOST=0.0.0.0
MONGODB_URL=mongodb://mongo:27017/kloudraksha
JWT_SECRET=change-me
COOKIE_SECRET=change-me-too

# Base URL that other services can reach (used by the audit microservice callback)
API_URL=http://backend:8000/api
# Optional override if the callback must use a different base URL
INTERNAL_API_URL=

# Flask audit microservice URL
AUDIT_SERVICE_URL=http://audit:6000

# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173,https://kloudraksha.com,https://www.kloudraksha.com

# Google Recaptcha secret if enabled
Recaptcha_site_secret=

# AWS + SES configuration (sender must belong to vaultix.in)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SENDER_EMAIL=noreply@vaultix.in
SCAN_REQUEST_NOTIFICATION_EMAIL=security@vaultix.in
