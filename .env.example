# Default ports
BACKEND_PORT=8000
FRONTEND_PORT=4173
AUDIT_PORT=6000
MONGO_PORT=27017

# Public URLs (relative path works through nginx proxy)
PUBLIC_API_URL=/api
CORS_ALLOWED_ORIGINS=http://localhost:4173,https://kloudraksha.com,https://www.kloudraksha.com

# Security secrets
JWT_SECRET=change-me
COOKIE_SECRET=change-this-too
RECAPTCHA_SECRET=

# AWS / SES / S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_SENDER_EMAIL=noreply@vaultix.in
SCAN_REQUEST_NOTIFICATION_EMAIL=security@vaultix.in
AWS_S3_BUCKET=
AWS_S3_PREFIX=prowler-reports
S3_PRESIGNED_TTL=300
PROWLER_IMAGE=toniblyx/prowler:latest
